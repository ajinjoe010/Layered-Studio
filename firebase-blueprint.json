{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A product available in the shop",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the product" },
        "name": { "type": "string", "description": "The name of the product" },
        "price": { "type": "number", "description": "The price of the product" },
        "description": { "type": "string", "description": "The description of the product" },
        "category": { "type": "string", "description": "The category of the product" },
        "images": { "type": "array", "items": { "type": "string" }, "description": "The images of the product" },
        "sizes": { "type": "array", "items": { "type": "string" }, "description": "The available sizes of the product" },
        "colors": { "type": "array", "items": { "type": "string" }, "description": "The available colors of the product" },
        "inStock": { "type": "boolean", "description": "Whether the product is in stock" },
        "isNew": { "type": "boolean", "description": "Whether the product is new" },
        "isTrending": { "type": "boolean", "description": "Whether the product is trending" },
        "discount": { "type": "number", "description": "The discount on the product" }
      },
      "required": ["name", "price", "category", "inStock"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the order" },
        "userId": { "type": "string", "description": "The unique identifier for the user who placed the order" },
        "customerName": { "type": "string", "description": "The name of the customer" },
        "date": { "type": "string", "format": "date-time", "description": "The date the order was placed" },
        "status": { "type": "string", "enum": ["Processing", "Shipped", "Delivered", "Cancelled"], "description": "The status of the order" },
        "total": { "type": "number", "description": "The total amount of the order" },
        "items": { "type": "array", "items": { "type": "object" }, "description": "The items in the order" }
      },
      "required": ["userId", "customerName", "date", "status", "total", "items"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique identifier for the user" },
        "email": { "type": "string", "format": "email", "description": "The email address of the user" },
        "displayName": { "type": "string", "description": "The display name of the user" },
        "photoURL": { "type": "string", "description": "The photo URL of the user" },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The role of the user" },
        "createdAt": { "type": "string", "format": "date-time", "description": "The date the user was created" }
      },
      "required": ["uid", "email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of orders"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of users"
    }
  }
}
